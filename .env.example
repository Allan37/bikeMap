VITE_MAPBOX_TOKEN=your_mapbox_public_token

# Server-side only (no VITE_ prefix — must never end up in the client bundle).
# Yelp Fusion has no CORS support and the key isn't safe to expose, so it's
# only ever read by api/yelp-search.ts / the local dev proxy, never the browser.
YELP_API_KEY=your_yelp_fusion_api_key

# Google Maps Platform key for in-app subway routing (Directions API, transit mode).
# Server-side only — proxied by api/transit-directions.ts, never shipped to the browser.
GOOGLE_MAPS_API_KEY=your_google_maps_platform_key
